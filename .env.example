# Meta Cloud API
META_ACCESS_TOKEN=seu_token_aqui
META_PHONE_NUMBER_ID=seu_phone_number_id
# Aliases legados aceitos pelo app:
# WHATSAPP_TOKEN=seu_token_aqui
# WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
META_APP_SECRET=seu_app_secret
META_VERIFY_TOKEN=token_webhook_verificacao
WEBHOOK_VERIFY_TOKEN=token_webhook_verificacao

# Chatwoot bridge
CHATWOOT_RELAY_ENABLED=true
CHATWOOT_WHATSAPP_WEBHOOK_URL=https://chat.anna.vps-kinghost.net/webhooks/whatsapp/+553171893255
CHATWOOT_RELAY_HOST=chat.anna.vps-kinghost.net
CHATWOOT_RELAY_PROTO=https
CHATWOOT_WEBHOOK_VERIFY_TOKEN=token_para_proteger_webhook_chatwoot
CHATWOOT_HUMAN_PAUSE_TTL_SECONDS=86400

# LLM
GEMINI_API_KEY=sua_chave_gemini
LLM_MODEL_TEXT=gemini-2.5-flash
LLM_MODEL_VISION=gemini-2.5-flash

# Database
DATABASE_URL=postgresql://agente:agente123@postgres:5432/agente_ana

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=troque-por-uma-string-aleatoria-longa
DASHBOARD_KEY=troque-por-uma-chave-para-dashboard
ENABLE_TEST_CHAT=false
AUTO_CREATE_TABLES=false
INACTIVITY_RESET_HOURS=1
DEBOUNCE_SECONDS=15
MESSAGE_DEBOUNCE_SECONDS=15
TYPING_INDICATOR_ENABLED=true
TURN_TIMEOUT_SECONDS=60
USE_AGENT_V2=false

# Dietbox (credenciais da conta da Thaynara)
DIETBOX_EMAIL=email@dominio.com
DIETBOX_SENHA=senha_dietbox
DIETBOX_ID_LOCAL_PRESENCIAL=  # preencher após primeiro login (auto-detectado)
DIETBOX_ID_LOCAL_ONLINE=      # preencher após primeiro login (auto-detectado)

# Gateway de pagamento
PAYMENT_GATEWAY=mercadopago    # "mercadopago" (padrão) ou "rede"
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_mp
MERCADOPAGO_WEBHOOK_URL=       # opcional — URL para notificações MP

# Rede (usar apenas se PAYMENT_GATEWAY=rede)
REDE_PV=seu_numero_pv
REDE_TOKEN=seu_token_rede

# Números internos (comandos e notificações)
THAYNARA_PHONE=5531991394759
BRENO_PHONE=5531992059211
ESCALATION_TEMPLATE_NAME=breno_escalacao_alerta
ESCALATION_TEMPLATE_LANGUAGE=pt_BR
