# Dominio publico do Chatwoot
CHATWOOT_DOMAIN=chat.seudominio.com
LETSENCRYPT_EMAIL=admin@seudominio.com

# URLs publicas
FRONTEND_URL=https://chat.seudominio.com
HELPCENTER_URL=https://chat.seudominio.com
FORCE_SSL=true

# Rails / Chatwoot
RAILS_ENV=production
SECRET_KEY_BASE=gere_um_hex_longo_com_openssl_rand_hex_64
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=gere_um_hex_longo_com_openssl_rand_hex_32
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=gere_um_hex_longo_com_openssl_rand_hex_32
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=gere_um_hex_longo_com_openssl_rand_hex_32
ENABLE_ACCOUNT_SIGNUP=false
DEFAULT_LOCALE=pt_BR
RAILS_LOG_TO_STDOUT=true
LOG_LEVEL=info
LOG_SIZE=500
INSTALLATION_ENV=docker

# Banco
POSTGRES_HOST=postgres
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=troque_esta_senha_postgres
RAILS_MAX_THREADS=5

# Redis
REDIS_URL=redis://:troque_esta_senha_redis@redis:6379
REDIS_PASSWORD=troque_esta_senha_redis

# Email
MAILER_SENDER_EMAIL=Chatwoot <no-reply@seudominio.com>
SMTP_DOMAIN=seudominio.com
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

# Armazenamento
ACTIVE_STORAGE_SERVICE=local

# Upload e notificacoes
DIRECT_UPLOADS_ENABLED=false
ENABLE_PUSH_RELAY_SERVER=true

# Referencia da sua integracao Meta / WhatsApp Cloud
# Estas variaveis nao sao lidas diretamente pelo container do Chatwoot no fluxo manual.
# Elas ficam centralizadas aqui para facilitar sua operacao.
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# O webhook abaixo e gerado pelo Chatwoot ao criar a inbox WhatsApp.
# Preencha depois de criar a inbox no painel:
# Settings -> Inboxes -> Add Inbox -> WhatsApp -> Manual setup
WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
